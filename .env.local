# ════════════════════════════════════════════════════════════════════
# .env.local — LOCAL development only (never commit real secrets here)
# ════════════════════════════════════════════════════════════════════
# Usage:
#   ./setup.sh local          ← recommended (auto-sources this file)
#   ./setup.sh local backend  ← restart only the backend
#   source .env.local && cd backend && uvicorn main:app --reload
#
# All values here are safe defaults for local-only development.
# No real credentials are needed to run the app locally.
# ════════════════════════════════════════════════════════════════════

# ── LLM ──────────────────────────────────────────────────────────────
OLLAMA_MODEL=phi3:mini
OLLAMA_URL=http://localhost:11434

# ── Database ──────────────────────────────────────────────────────────
# setup.sh sets DATABASE_URL automatically from MAO_DB_NAME.
# Override here only if you use a non-default Postgres setup.
# DATABASE_URL=postgres://localhost/mao_local
MAO_DB_NAME=mao_local

# ── Auth (API key — DISABLED for local) ──────────────────────────────
# No API key required locally. Any request is accepted.
REQUIRE_API_KEY=false
MASTER_API_KEY=

# ── Auth (Google OAuth) ────────────────────────────────────────────────
# Leave GOOGLE_CLIENT_ID empty to disable OAuth locally.
# The backend auth routes still exist; the frontend hides the login button
# when the client ID is absent.
#
# To test OAuth locally:
#   1. Create an OAuth 2.0 Client at https://console.cloud.google.com/
#      Application type: Web application
#      Authorised redirect URIs: http://localhost:8000/auth/callback/google
#   2. Fill in the values below and uncomment.
#
# GOOGLE_CLIENT_ID=your-client-id.apps.googleusercontent.com
# GOOGLE_CLIENT_SECRET=your-secret
GOOGLE_REDIRECT_URI=http://localhost:8000/auth/callback/google

# ── Auth (Email-based authorisation) ─────────────────────────────────
# Empty = any Google account can log in (fine for local testing).
# Set to restrict: ALLOWED_EMAIL_DOMAINS=gmail.com,yourcompany.com
ALLOWED_EMAIL_DOMAINS=
ALLOWED_EMAILS=
ADMIN_EMAILS=

# ── Session JWT ───────────────────────────────────────────────────────
# Safe local-only secret.  MUST be changed for dev/production.
SESSION_SECRET=local-dev-secret-change-in-prod
SESSION_COOKIE_NAME=mao_session
SESSION_TTL_HOURS=8

# After Google OAuth login, redirect back to the Vite dev server.
OAUTH_SUCCESS_REDIRECT=http://localhost:5173

# ── CORS ──────────────────────────────────────────────────────────────
ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173,http://localhost:3000

# ── Features ──────────────────────────────────────────────────────────
SEARCH_ENABLED=true
RAG_ENABLED=true
TELEGRAM_ENABLED=false
SELF_IMPROVER_ENABLED=true
AGENT_SPAWN_ENABLED=true
TOOL_SPAWN_ENABLED=true
FILESYSTEM_ENABLED=true
STATS_ENABLED=true

# ── Logging ───────────────────────────────────────────────────────────
LOG_LEVEL=DEBUG
LOG_TO_FILE=false
