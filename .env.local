# ════════════════════════════════════════════════════════════════════
# .env.local — LOCAL development only (never commit secrets here)
# ════════════════════════════════════════════════════════════════════
# Usage:
#   source .env.local && cd backend && uvicorn main:app --reload
#   OR let setup.sh load it automatically: ./setup.sh local
#
# This file is intentionally committed so any developer can clone +
# run with zero config.  Sensitive production values go in .env.cloud
# ════════════════════════════════════════════════════════════════════

# ── LLM ──────────────────────────────────────────────────────────────
OLLAMA_MODEL=phi3:mini
OLLAMA_URL=http://localhost:11434

# ── Auth  (DISABLED for local — no API key needed) ───────────────────
REQUIRE_API_KEY=false
MASTER_API_KEY=

# ── Google OAuth (fill in when testing OAuth locally) ─────────────────
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=
# GOOGLE_REDIRECT_URI=http://localhost:8000/auth/callback/google
# ALLOWED_EMAIL_DOMAINS=gmail.com
# ADMIN_EMAILS=
# SESSION_SECRET=local-dev-secret-change-in-prod

# ── CORS ──────────────────────────────────────────────────────────────
ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173,http://localhost:3000

# ── Features ──────────────────────────────────────────────────────────
SEARCH_ENABLED=true
RAG_ENABLED=true
TELEGRAM_ENABLED=false
SELF_IMPROVER_ENABLED=true
AGENT_SPAWN_ENABLED=true
TOOL_SPAWN_ENABLED=true
FILESYSTEM_ENABLED=true
STATS_ENABLED=true

# ── Logging ───────────────────────────────────────────────────────────
LOG_LEVEL=INFO
