# .env.production.example — Copy to .env.production and fill in real values.
# DO NOT commit .env.production — it contains secrets.

MAO_DB_NAME=mao_production
REQUIRE_API_KEY=true
MASTER_API_KEY=<replace-with-strong-secret>

# Google OAuth (required for browser login in production)
GOOGLE_CLIENT_ID=<your-project>.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=<your-oauth-secret>
GOOGLE_REDIRECT_URI=https://yourdomain.com/auth/callback/google
OAUTH_SUCCESS_REDIRECT=https://yourdomain.com

# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
SESSION_SECRET=<32-byte-random-hex>

# Email access control
# Only these domains can log in (leave empty to allow any Google account)
ALLOWED_EMAIL_DOMAINS=yourcompany.com
# Always-allowed individual addresses (comma-separated)
# ALLOWED_EMAILS=partner@otherdomain.com
# These users get plan=enterprise and is_admin=true
ADMIN_EMAILS=admin@yourcompany.com

# Server
GUNICORN_WORKERS=4
BACKEND_PORT=8000

# CORS — must match your frontend origin exactly
ALLOWED_ORIGINS=https://yourdomain.com

# Optional: override the Ollama model for production
# OLLAMA_MODEL=llama3.1:8b
