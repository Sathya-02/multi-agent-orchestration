# .env.production.example — template for production environment
# Copy to .env.production and fill in real values. NEVER commit .env.production.
# Loaded automatically by: ./setup.sh production

# ── Database ──────────────────────────────────────────────────────────────
MAO_DB_NAME=mao_production
# Full connection string takes priority over MAO_DB_NAME.
# DATABASE_URL=postgres://mao_user:STRONG_PASSWORD@db-host:5432/mao_production

# ── Auth ──────────────────────────────────────────────────────────────────
REQUIRE_API_KEY=true
MASTER_API_KEY=REPLACE_WITH_STRONG_SECRET_KEY

# ── Google OAuth ─────────────────────────────────────────────────────────
# Create credentials at https://console.cloud.google.com/
# Add https://yourdomain.com/auth/callback/google as an Authorised redirect URI.
GOOGLE_CLIENT_ID=YOUR_PROD_CLIENT_ID.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=YOUR_PROD_CLIENT_SECRET
GOOGLE_REDIRECT_URI=https://yourdomain.com/auth/callback/google
OAUTH_SUCCESS_REDIRECT=https://yourdomain.com

# ── Session JWT ───────────────────────────────────────────────────────────
# Generate a strong random secret: python -c "import secrets; print(secrets.token_hex(32))"
SESSION_SECRET=REPLACE_WITH_STRONG_RANDOM_SECRET
SESSION_COOKIE_NAME=mao_session
SESSION_TTL_HOURS=8

# ── Email-based authorisation ─────────────────────────────────────────────
# Only users from these domains can log in (comma-separated).
# Empty = any Google account is allowed (use with caution in production).
ALLOWED_EMAIL_DOMAINS=yourcompany.com
# Explicit individual overrides (always allowed regardless of domain rule).
# ALLOWED_EMAILS=external.partner@gmail.com
# Users in ADMIN_EMAILS get plan=enterprise and is_admin=true.
ADMIN_EMAILS=admin@yourcompany.com

# ── LLM ──────────────────────────────────────────────────────────────────
# Point to a cloud GPU endpoint or keep using a local Ollama instance.
OLLAMA_MODEL=llama3:8b
OLLAMA_URL=http://localhost:11434
# For OpenAI-compatible API:
# OLLAMA_URL=https://api.openai.com/v1
# OLLAMA_MODEL=gpt-4o

# ── Server ────────────────────────────────────────────────────────────────
BACKEND_PORT=8000
GUNICORN_WORKERS=4
ALLOWED_ORIGINS=https://yourdomain.com

# ── Features ─────────────────────────────────────────────────────────────
SEARCH_ENABLED=true
RAG_ENABLED=true
TELEGRAM_ENABLED=false
SELF_IMPROVER_ENABLED=true
FILESYSTEM_ENABLED=true
STATS_ENABLED=true

# ── Logging ──────────────────────────────────────────────────────────────
LOG_LEVEL=INFO
LOG_TO_FILE=true
