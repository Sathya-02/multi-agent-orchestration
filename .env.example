# ════════════════════════════════════════════════════════════════════════
# .env.example — Local Development Environment Variables
# ════════════════════════════════════════════════════════════════════════
#
# Copy this file to .env and fill in any values you want to change.
# Defaults are set in settings.py — you only need to override here.
#
#   cp .env.example .env
#   docker compose --env-file .env up -d
#
# For Mac (Ollama running on host, not in Docker):
#   OLLAMA_URL=http://host.docker.internal:11434
# ════════════════════════════════════════════════════════════════════════

# ── LLM ──────────────────────────────────────────────────────────────────
OLLAMA_MODEL=phi3:mini
OLLAMA_URL=http://ollama:11434

# ── Features ──────────────────────────────────────────────────────────────
SEARCH_ENABLED=true
RAG_ENABLED=true
TELEGRAM_ENABLED=false
SELF_IMPROVER_ENABLED=true
AGENT_SPAWN_ENABLED=true
TOOL_SPAWN_ENABLED=true
FILESYSTEM_ENABLED=true

# ── Telegram (optional) ────────────────────────────────────────────────
TELEGRAM_BOT_TOKEN=
TELEGRAM_ALLOWED_CHAT_IDS=
TELEGRAM_NOTIFY_CHAT_ID=

# ── Auth (local — leave blank) ─────────────────────────────────────────
REQUIRE_API_KEY=false
MASTER_API_KEY=

# ── CORS ────────────────────────────────────────────────────────────────
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173
