# .env.dev — development / staging environment
# Loaded automatically by: ./setup.sh dev
# DO NOT commit real secrets. Add .env.dev to .gitignore.

# ── Database ──────────────────────────────────────────────────────────────
MAO_DB_NAME=mao_dev
# DATABASE_URL=postgres://user:pass@localhost:5432/mao_dev

# ── Auth ──────────────────────────────────────────────────────────────────
REQUIRE_API_KEY=false
MASTER_API_KEY=dev-master-key-change-me

# ── Google OAuth ─────────────────────────────────────────────────────────
# GOOGLE_CLIENT_ID=your-dev-client-id.apps.googleusercontent.com
# GOOGLE_CLIENT_SECRET=your-dev-secret
GOOGLE_REDIRECT_URI=http://localhost:8000/auth/callback/google
OAUTH_SUCCESS_REDIRECT=http://localhost:5173

# ── Session JWT ───────────────────────────────────────────────────────────
SESSION_SECRET=dev-secret-change-before-deploy
SESSION_COOKIE_NAME=mao_session
SESSION_TTL_HOURS=8

# ── Email-based authorisation ─────────────────────────────────────────────
# ALLOWED_EMAIL_DOMAINS=yourcompany.com
# ADMIN_EMAILS=admin@yourcompany.com

# ── LLM / Ollama ─────────────────────────────────────────────────────────
OLLAMA_MODEL=phi3:mini
OLLAMA_URL=http://localhost:11434

# ── Features ─────────────────────────────────────────────────────────────
SEARCH_ENABLED=true
RAG_ENABLED=true
TELEGRAM_ENABLED=false
SELF_IMPROVER_ENABLED=true
FILESYSTEM_ENABLED=true
STATS_ENABLED=true

# ── Ports ────────────────────────────────────────────────────────────────
BACKEND_PORT=8000
FRONTEND_PORT=5173

# ── Logging ──────────────────────────────────────────────────────────────
LOG_LEVEL=DEBUG
LOG_TO_FILE=false
