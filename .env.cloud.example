# ════════════════════════════════════════════════════════════════════════
# .env.cloud.example — Production Cloud Environment Variables
# ════════════════════════════════════════════════════════════════════════
#
#   cp .env.cloud.example .env.cloud
#   # Fill in all values marked REQUIRED
#   docker compose -f docker-compose.yml -f docker-compose.cloud.yml \
#     --env-file .env.cloud up -d
# ════════════════════════════════════════════════════════════════════════

# ── Domain & TLS ──────────────────────────────────────────────────────
# REQUIRED: your actual domain name
DOMAIN=agents.yourdomain.com

# REQUIRED: email for Let's Encrypt certificate notifications
ACME_EMAIL=admin@yourdomain.com

# ── Security ──────────────────────────────────────────────────────────
# REQUIRED: generate with: openssl rand -hex 32
MASTER_API_KEY=replace-with-32-byte-hex-secret

# REQUIRED: generate with: openssl rand -base64 24
POSTGRES_PASSWORD=replace-with-strong-db-password

# REQUIRED: generate with: openssl rand -base64 24
REDIS_PASSWORD=replace-with-strong-redis-password

# ── LLM ──────────────────────────────────────────────────────────────
OLLAMA_MODEL=llama3.2:3b
OLLAMA_URL=http://ollama:11434

# ── Features ──────────────────────────────────────────────────────────
SEARCH_ENABLED=true
RAG_ENABLED=true
TELEGRAM_ENABLED=true
SELF_IMPROVER_ENABLED=true
AGENT_SPAWN_ENABLED=true
TOOL_SPAWN_ENABLED=true
FILESYSTEM_ENABLED=false    # keep off for shared cloud deployments

# ── Telegram ──────────────────────────────────────────────────────────
TELEGRAM_BOT_TOKEN=your-bot-token-from-botfather
TELEGRAM_ALLOWED_CHAT_IDS=123456789
TELEGRAM_NOTIFY_CHAT_ID=123456789

# ── Multi-user limits ─────────────────────────────────────────────────
REQUIRE_API_KEY=true
MAX_JOBS_PER_KEY=3
JOB_TIMEOUT_SECONDS=600

# ── Logging ──────────────────────────────────────────────────────────
LOG_LEVEL=WARNING
